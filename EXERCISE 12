SQL> -- Step 3: Create Function
SQL> CREATE OR REPLACE FUNCTION get_salary (
  2      p_emp_id IN NUMBER
  3  ) RETURN NUMBER
  4  AS
  5      v_salary NUMBER;
  6  BEGIN
  7      SELECT salary
  8      INTO v_salary
  9      FROM test_employees
 10      WHERE emp_id = p_emp_id;
 11
 12      RETURN v_salary; -- Return salary value
 13  EXCEPTION
 14      WHEN NO_DATA_FOUND THEN
 15          RETURN NULL; -- Return NULL if no employee found
 16  END;
 17  /
Function created.
SQL>
SQL> -- Step 4: Call function from PL/SQL block
SQL> BEGIN
  2      DBMS_OUTPUT.PUT_LINE('Salary of Employee 101: ' || get_salary(101));
  3  END;
  4  /
