SQL> -- Step 3: Create Procedure
SQL> CREATE OR REPLACE PROCEDURE give_raise (
  2      p_emp_id IN NUMBER,
  3      p_amount IN NUMBER
  4  ) AS
  5  BEGIN
  6      UPDATE test_employees
  7      SET salary = salary + p_amount
  8      WHERE emp_id = p_emp_id;
  9
 10      IF SQL%FOUND THEN
 11          DBMS_OUTPUT.PUT_LINE('Salary updated for Employee ID: ' || p_emp_id);
 12          DBMS_OUTPUT.PUT_LINE('Rows affected: ' || SQL%ROWCOUNT);
 13      ELSE
 14          DBMS_OUTPUT.PUT_LINE('No employee found with ID: ' || p_emp_id);
 15      END IF;
 16  END;
